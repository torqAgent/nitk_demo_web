# LiveKit — used server-side only, to mint room tokens and dispatch the
# nitk-library-agent worker into the room. Never expose these to the client.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# DeepSeek — used server-side only, by the Aria text chat route. Called
# directly, no LiveKit or agent worker involved for text chat.
DEEPSEEK_API_KEY=
